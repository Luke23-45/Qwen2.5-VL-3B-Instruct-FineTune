# ──────────────────────────────────────────────────────────────
# KrishiVaidya Inference API — Example Environment Variables
# Copy this to .env and fill in your values.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
KRISHI_API_HOST=0.0.0.0
KRISHI_API_PORT=8000
KRISHI_DEBUG=True

# ── vLLM backend ────────────────────────────────────────────
KRISHI_VLLM_BASE_URL=http://localhost:8080
KRISHI_VLLM_MODEL_NAME=Qwen/Qwen2.5-VL-3B-Instruct

# ── JWT Authentication ──────────────────────────────────────
KRISHI_JWT_PUBLIC_KEY_PATH=./keys/public_key.pem
KRISHI_JWT_PRIVATE_KEY_PATH=./keys/private_key.pem

# ── Ngrok (Development/Tunnelling) ──────────────────────────
# Set KRISHI_NGROK_ENABLED=True to expose the API via ngrok.
KRISHI_NGROK_ENABLED=False
# 1. Get your Auth Token from https://dashboard.ngrok.com/get-started/your-authtoken
# 2. Claim your 1 Free Static Domain from https://dashboard.ngrok.com/cloud-edge/domains
KRISHI_NGROK_AUTHTOKEN=
KRISHI_NGROK_DOMAIN=

# ── Rate limiting ───────────────────────────────────────────
KRISHI_RATE_LIMIT=30/minute
