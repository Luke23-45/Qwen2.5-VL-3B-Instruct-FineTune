# KrishiVaidya Inference API - cloud environment example

# Gateway server
# KRISHI_API_HOST=0.0.0.0
# KRISHI_API_PORT=8000
# KRISHI_DEBUG=False

# vLLM backend
# Keep vLLM private to the cloud host or VPC when possible.
KRISHI_VLLM_BASE_URL=http://127.0.0.1:8080
# KRISHI_VLLM_MODEL_NAME=Qwen/Qwen2.5-VL-3B-Instruct
# KRISHI_VLLM_TIMEOUT_SECONDS=60

# JWT authentication
# Provide exactly one public-key source in production.
KRISHI_JWT_PUBLIC_KEY_PATH=/opt/krishivaidya/secrets/public_key.pem
# KRISHI_JWT_PUBLIC_KEY_CONTENT="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# KRISHI_JWT_ALGORITHM=RS256
# KRISHI_JWT_ISSUER=krishivaidya
# KRISHI_JWT_AUDIENCE=krishivaidya-inference

# Ngrok (development only)
# KRISHI_NGROK_AUTHTOKEN=your_ngrok_auth_token_here
# KRISHI_NGROK_DOMAIN=your-custom-domain.ngrok-free.app

# Image validation and limits
# KRISHI_MAX_IMAGE_SIZE_BYTES=10485760
# KRISHI_MAX_IMAGE_DIMENSION=4096
# KRISHI_MIN_IMAGE_DIMENSION=28
# KRISHI_IMAGE_URL_FETCH_TIMEOUT_SECONDS=10

# Rate limiting
# KRISHI_RATE_LIMIT=30/minute
